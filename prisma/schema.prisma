generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppSnapshot {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TmdbCacheEntry {
  key       String   @id
  kind      String
  payload   Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([kind, expiresAt])
}

model UserRecord {
  id           String   @id
  name         String
  username     String   @unique
  email        String
  avatarSeed   String?
  avatarUrl    String?
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([username])
}

model MovieRecord {
  id        String   @id
  slug      String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model PendingMovie {
  groupId String
  movieId String
  addedAt DateTime @default(now())

  @@id([groupId, movieId])
  @@index([groupId, addedAt])
}

model WatchEntryRecord {
  id              String   @id
  movieId         String   @unique
  groupId         String
  watchedOn       DateTime?
  selectedForWeek String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId, watchedOn])
}

model RatingRecord {
  id        String   @id
  movieId   String
  userId    String
  score     Float
  comment   String?
  watchedOn DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movieId, userId])
  @@index([movieId])
  @@index([userId])
}

model WeeklyBatchRecord {
  id              String                  @id
  groupId         String
  weekOf          DateTime
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  selectedMovieId String?
  items           WeeklyBatchItemRecord[]

  @@index([groupId, createdAt])
}

model WeeklyBatchItemRecord {
  id       String            @id
  batchId  String
  movieId  String
  position Int               @default(0)
  score    Float
  summary  String
  reasons  Json
  metrics  Json?
  batch    WeeklyBatchRecord @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, position])
}
