generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppSnapshot {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TmdbCacheEntry {
  key       String   @id
  kind      String
  payload   Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([kind, expiresAt])
}
