generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppSnapshot {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TmdbCacheEntry {
  key       String   @id
  kind      String
  payload   Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([kind, expiresAt])
}

model PendingMovie {
  groupId String
  movieId String
  addedAt DateTime @default(now())

  @@id([groupId, movieId])
  @@index([groupId, addedAt])
}

model WatchEntryRecord {
  id              String   @id
  movieId         String   @unique
  groupId         String
  watchedOn       DateTime?
  selectedForWeek String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId, watchedOn])
}

model RatingRecord {
  id        String   @id
  movieId   String
  userId    String
  score     Float
  comment   String?
  watchedOn DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movieId, userId])
  @@index([movieId])
  @@index([userId])
}
